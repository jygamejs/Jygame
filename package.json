  "scripts": {
    "test": "echo \"No tests yet\" && exit 0",
    "build:wasm": "node tools/particles/build-wasm.mjs",
    "build:wasm:verify": "node -e \"import('fs').then(f=>{const w=f.readFileSync('particles/backends/death_sweep.wasm');WebAssembly.instantiate(w).then(i=>{console.log('deathSweepFull:',typeof i.instance.exports.deathSweepFull)})})\""
  },
  "devDependencies": {
    "wabt": "^1.0.39"
  },
  "dependencies": {}
