  "keywords": [
    "game",
    "game-development",
    "2d",
    "canvas",
    "framework"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bouzidi-Youssef/Jygame.git"
  },
  "homepage": "https://jygame-documentation.vercel.app/",
