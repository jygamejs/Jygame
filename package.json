{
  "name": "jygame",
  "version": "0.7.7",

  "description": "A lightweight 2D game framework for the browser",
  "type": "module",
  "main": "./jygame.js",
  "exports": {
    ".": "./jygame.js"
  },
  "files": [
    "jygame.js",
    "math/",
    "geometry/",
    "time/",
    "state/",
    "storage/",
    "collision/",
